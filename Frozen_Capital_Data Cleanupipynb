      "cell_type": "code",
      "source": [
        "for sheet_name, df in cleaned_sheets.items():\n",
        "    # 1. Clean Category & Storage Type formatting\n",
        "    if 'Category' in df.columns:\n",
        "        df['Category'] = df['Category'].astype(str).str.strip().str.title()\n",
