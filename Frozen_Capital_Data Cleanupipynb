        "        df['Storage_Type'] = df['Storage_Type'].astype(str).str.strip().str.title()\n",
        "\n",
        "    # 2. Validate and map Warehouse column to our exact schema (WH1, WH2, etc.)\n",
        "    if 'Warehouse' in df.columns:\n",
