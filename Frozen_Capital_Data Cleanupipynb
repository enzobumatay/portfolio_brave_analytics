    {
      "cell_type": "code",
      "source": [
        "print(\"STANDARDIZING DATE FORMATS\\n\")\n",
        "\n",
        "for sheet_name, df in cleaned_sheets.items():\n",
        "    if 'Date' in df.columns:\n",
        "        # 1. Quick Check: Profile the unique date formats present before cleaning\n",
        "        print(f\"Sample values from [{sheet_name}] before formatting:\")\n",
        "        print(df['Date'].dropna().head(2).tolist())\n",
        "\n",
        "        # 2. Convert to a unified datetime object (coercing errors to NaT safely)\n",
        "        df['Date'] = pd.to_datetime(df['Date'], errors='coerce')\n",
        "\n",
        "        # 3. Format explicitly to MM/DD/YYYY string schema\n",
        "        df['Date'] = df['Date'].dt.strftime('%m/%d/%Y')\n",
        "\n",
        "        # 4. Quick Check: Verify the result\n",
        "        print(f\"✨ Sample values from [{sheet_name}] after formatting:\")\n",
        "        print(df['Date'].dropna().head(2).tolist())\n",
        "        print(\"-\" * 50)"
