    {
      "cell_type": "markdown",
      "source": [
        "### Isolating and Flagging Missing Data"
      ],
      "metadata": {
        "id": "nwizjKpJzgHk"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Instead of deleting rows with missing values, I will add a new tracking column called Data_Quality_Flag. This is to track also the missed records, which are essential in the system.\n",
        "\n",
        "# Initialize a dictionary to store processed dataframes\n",
        "cleaned_sheets = {}\n",
        "\n",
        "# Create a copy of the excel sheets\n",
        "for sheet in source_file.sheet_names:\n",
        "    df = pd.read_excel(source_file, sheet_name=sheet)\n",
        "\n",
        "    # Check if any cell in a row contains a blank/NaN value\n",
        "    has_nulls = df.isnull().any(axis=1)\n",
        "\n",
        "    # Flag rows as 'Missing Data' or 'Clean'\n",
        "    df['Data_Quality_Flag'] = np.where(has_nulls, 'Missing Data', 'Clean')\n",
        "\n",
        "    # Store the new data in the dictionary\n",
        "    cleaned_sheets[sheet] = df\n",
        "\n",
        "# Quick EDA Check: Verify the flag distribution across all sheets\n",
        "print(\" DATA QUALITY FLAG SUMMARY \\n\")\n",
        "for sheet_name, df in cleaned_sheets.items():\n",
        "    print(f\"📄 Sheet: [{sheet_name}]\")\n",
        "    print(df['Data_Quality_Flag'].value_counts().to_string())\n",
        "    print(\"-\" * 40)"
      ],
